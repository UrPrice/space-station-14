<DefaultWindow xmlns="https://spacestation14.io"
            xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client">
    <BoxContainer Orientation="Vertical" SeparationOverride="5">
        <!-- ss220-better-xaml-ui-instrument-bgn -->
        <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="10">
            <Button Name="InputButton" ToggleMode="True" Text="{Loc 'instruments-component-menu-input-button'}" TextAlign="Center" HorizontalExpand="True" StyleClasses="OpenRight"/>
            <Button Name="BandButton" Text="{Loc 'instruments-component-menu-band-button'}" TextAlign="Center" HorizontalExpand="True" StyleClasses="OpenBoth"/>
            <Button Name="FileButton" Text="{Loc 'instruments-component-menu-play-button'}" TextAlign="Center" HorizontalExpand="True" StyleClasses="OpenLeft"/>
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="10">
            <Button Name="LoopButton" ToggleMode="True" Text="{Loc 'instruments-component-menu-loop-button'}" TextAlign="Center" HorizontalExpand="True" StyleClasses="OpenRight"/>
            <Button Name="ChannelsButton" Text="{Loc 'instruments-component-menu-channels-button'}" TextAlign="Center" HorizontalExpand="True" StyleClasses="OpenBoth"/>
            <Button Name="StopButton" Text="{Loc 'instruments-component-menu-stop-button'}" TextAlign="Center" HorizontalExpand="True" StyleClasses="OpenLeft"/>
        </BoxContainer>
        <!-- ss220-better-xaml-ui-instrument-end -->
        <BoxContainer Orientation="Horizontal" VerticalExpand="True">
            <Slider Name="PlaybackSlider" HorizontalExpand="True" />
        </BoxContainer>
    </BoxContainer>
    <PanelContainer Name="UnavailableOverlay" Visible="False" MouseFilter="Stop">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BackgroundColor="#000000E5" />
        </PanelContainer.PanelOverride>
        <Label VerticalAlignment="Center" HorizontalAlignment="Center" Align="Center"
               StyleClasses="LabelBig"
               Text="{Loc instruments-component-menu-no-midi-support}" />
    </PanelContainer>
</DefaultWindow>
